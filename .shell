#!/bin/sh

shell_has_cmd() {
	command -v "$1" >/dev/null
}

shell_add_path() {
	mkdir -p "$1" || return
	f=$(cd "$1" && pwd)
	case ":$PATH:" in (*":$f:"*) ;;
	(*) export PATH="$f${PATH:+:$PATH}"
	esac
	unset f
}

shell_add_ld_library_path() {
	mkdir -p "$1" || return
	f=$(cd "$1" && pwd)
	case ":$LD_LIBRARY_PATH:" in (*":$f:"*) ;;
	(*) export LD_LIBRARY_PATH="$f${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
	esac
	unset f
}

shell_add_dyld_library_path() {
	mkdir -p "$1" || return
	f=$(cd "$1" && pwd)
	case ":$DYLD_LIBRARY_PATH:" in (*":$f:"*) ;;
	(*) export DYLD_LIBRARY_PATH="$f${DYLD_LIBRARY_PATH:+:$DYLD_LIBRARY_PATH}"
	esac
	unset f
}

shell_add_lib_path() {
	case "$(uname -s)" in
	(Darwin) shell_add_dyld_library_path "$@" ;;
	(Linux) shell_add_ld_library_path "$@" ;;
	esac
}

shell_add_manpath() {
	mkdir -p "$1" || return
	f=$(cd "$1" && pwd)
	case ":$MANPATH:" in (*":$f:"*) ;;
	(*) export MANPATH="$f${MANPATH:+:$MANPATH}"
	esac
	unset f
}

shell_source() {
	[ "$1" ] || return
	set -- "${1%/}"
	for _ss_x in sh \
		${BASH##*/} \
		${YASH_VERSION+yash} \
		${ZSH_VERSION+zsh} \
		${KSH_VERSION+ksh}
	do
		[ "$_ss_x" ] || continue
		[ -d "$1" ] && _ss_g="$1/*.$_ss_x" || _ss_g="$1.$_ss_x"
		for _ss_f in $_ss_g
		do [ -f "$_ss_f" ] && . "$_ss_f"
		done 2>/dev/null
	done
	unset _ss_x _ss_g _ss_f
}

shell_reload() {
	USER=$(id -un)
	[ "$HOME" ] || eval "HOME=~$USER"
	export USER HOME
	export PATH="/usr/bin:/bin:/usr/sbin:/sbin:/usr/local/bin"
	export MANPATH="/usr/share/man:/usr/local/share/man"
	unset LD_PRELOAD LD_LIBRARY_PATH DYLD_LIBRARY_PATH
	shell_add_path ~/.bin
	shell_source ~/.shell.d
	[ -f ~/.local.sh ] && . ~/.local.sh
	hash -r 2>/dev/null || :
}

shell_reload
